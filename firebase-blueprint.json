{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["farmer", "rancher", "buyer", "transporter", "admin"] },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "phone": { "type": "string" },
        "totalEarnings": { "type": "number", "description": "Total accumulated earnings from sales or deliveries" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Agricultural product listed by a farmer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "farmerId": { "type": "string" },
        "farmerName": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "harvestDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["available", "harvesting", "sold"] },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["farmerId", "name", "quantity", "unit", "price", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Order placed by a buyer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "farmerId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "totalAmount": { "type": "number" },
        "freightFee": { "type": "number" },
        "transporterId": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["ussd", "bank_transfer", "cash"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "freightPaymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "delivered"] },
        "deliveryAddress": { "type": "string" },
        "farmerLat": { "type": "number" },
        "farmerLng": { "type": "number" },
        "buyerLat": { "type": "number" },
        "buyerLng": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "farmerId", "productId", "quantity", "totalAmount", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "relatedId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "Item in a buyer's shopping cart",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "farmerId": { "type": "string" },
        "farmerName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "quantity", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order records"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/cart/{cartItemId}": {
      "schema": "CartItem",
      "description": "Shopping cart items"
    }
  }
}
